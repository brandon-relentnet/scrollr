{
    "manifest_version": 3,
    "name": "Scrollr",
    "version": "1.0",
    "description": "A browser extension to control scrolling speed.",
    "permissions": ["storage", "activeTab", "tabs"],
    "background": {
      "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
